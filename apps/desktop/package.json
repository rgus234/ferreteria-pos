{
  "name": "nexo-pos-desktop",
  "version": "1.0.1",
  "description": "Nexo POS para Windows",
  "author": "Nexo POS",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "check": "node --check main.js && node --check preload.js && node --check local-db.js && node --check renderer/activation.js",
    "rebuild": "electron-builder install-app-deps",
    "dist": "electron-builder --win nsis",
    "dist:win": "electron-builder --win nsis --publish never",
    "dist:win:signed": "electron-builder --win nsis --publish never --config electron-builder.signed.yml"
  },
  "build": {
    "appId": "com.nexopos.desktop",
    "productName": "Nexo POS",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "local-db.js",
      "preload.js",
      "renderer/**",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "NexoPOS_Setup_${version}.${ext}",
      "signExecutable": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "rgus234",
        "repo": "ferreteria-pos"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Nexo POS",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  },
  "dependencies": {
    "better-sqlite3": "12.11.1",
    "electron-updater": "6.8.9"
  },
  "devDependencies": {
    "electron": "42.5.0",
    "electron-builder": "26.15.3"
  }
}
