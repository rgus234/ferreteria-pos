APP_NAME=Nexo POS
APP_ENV=development
APP_VERSION=1.0.0-dev
PORT=3000

# PostgreSQL
# DEV: usa una base de pruebas.
# PROD: usa una base exclusiva del cliente.
DATABASE_URL=postgres://usuario:password@localhost:5432/nexo_pos_dev

# Usa require cuando el proveedor de nube lo pida.
PGSSLMODE=disable

# Clave para entrar al panel /admin.
# En desarrollo puedes poner algo simple, en produccion usa una clave larga.
ADMIN_KEY=cambia-esta-clave

# Dominio publico real (sin barra al final), usado para armar los
# enlaces de los correos. En desarrollo dejalo vacio -- sin esto,
# los enlaces usan automaticamente localhost.
APP_BASE_URL=

# Resend (correo transaccional): verificacion de cuenta, recuperacion
# de contrasena. Consigue tu API key en https://resend.com/api-keys
RESEND_API_KEY=
# Remitente de los correos. Mientras no verifiques un dominio propio
# en Resend, usa su remitente de pruebas onboarding@resend.dev.
RESEND_FROM=onboarding@resend.dev
