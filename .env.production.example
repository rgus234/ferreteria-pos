APP_NAME=Nexo POS
APP_ENV=production
APP_VERSION=1.0.0
PORT=3000

# PostgreSQL de produccion.
# Usar una base separada por cliente al inicio.
DATABASE_URL=postgres://usuario:password@host:5432/nexo_pos_cliente_001?sslmode=require
PGSSLMODE=require

# Clave privada para administrar licencias en /admin.
ADMIN_KEY=pon-aqui-una-clave-larga

# Dominio publico de la APP (sin barra al final) -- no el dominio
# principal de la landing comercial. Se usa para armar los enlaces de
# los correos (verificacion, activacion, recuperacion). Ponlo solo
# cuando el subdominio ya este activo -- mientras tanto, dejar vacio
# usa automaticamente el host de la petición.
APP_BASE_URL=https://app.nexoposoficial.com

# Resend (correo transaccional): verificacion de cuenta, recuperacion
# de contrasena. Consigue tu API key en https://resend.com/api-keys
RESEND_API_KEY=

# Remitente de los correos. Cambialo al dominio propio SOLO despues
# de que Resend marque el dominio como verificado en
# https://resend.com/domains -- si lo pones antes, todos los correos
# empiezan a fallar.
RESEND_FROM=onboarding@resend.dev

# Stripe (cobro de suscripciones). NO pongas llaves sk_live_/whsec_
# reales aqui hasta confirmar explicitamente que se quiere aceptar
# pagos reales -- mientras tanto usa llaves sk_test_/whsec_ de prueba,
# igual que en desarrollo.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASICO=
STRIPE_PRICE_PLUS=
STRIPE_PRICE_PRO=

# Nexo IA (chat con datos reales del negocio). No existe "modo
# prueba" -- cada mensaje real consume esta API key y tiene costo.
ANTHROPIC_API_KEY=

# Correo del operador de la plataforma para el respaldo diario de la
# base completa. Sin esta variable, el respaldo sigue corriendo y
# queda registrado en la bitacora, solo no se envia por correo.
RESPALDO_EMAIL_DESTINO=
