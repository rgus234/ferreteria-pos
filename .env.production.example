APP_NAME=Nexo POS
APP_ENV=production
APP_VERSION=0.1.0
PORT=3000

# PostgreSQL de produccion.
# Usar una base separada por cliente al inicio.
DATABASE_URL=postgres://usuario:password@host:5432/nexo_pos_cliente_001?sslmode=require
PGSSLMODE=require

# Clave privada para administrar licencias en /admin.
ADMIN_KEY=pon-aqui-una-clave-larga
